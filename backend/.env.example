PUBLIC_SITE_URL=http://localhost:3004

# 数据库环境和签名运行环境分开控制。
# 日常本地开发建议：DATABASE_TARGET=local 且 SIGN_RUNTIME_TARGET=local。
# 本地连线上数据库排查问题时，建议：DATABASE_TARGET=production 且 SIGN_RUNTIME_TARGET=local。
# 只有代码真正运行在 VPS 上时，才建议把 SIGN_RUNTIME_TARGET 改成 production。
# 如果直接填写不带后缀的主变量，会优先使用它。
# 如果主变量留空，则根据 SIGN_RUNTIME_TARGET 自动选择 *_LOCAL / *_PRODUCTION / *_STAGING / *_TEST。
